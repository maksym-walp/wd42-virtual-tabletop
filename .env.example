# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=walp_tabletop
POSTGRES_USER=walp_user
POSTGRES_PASSWORD=change_me_in_production

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — frontend public URL
FRONTEND_URL=http://localhost

# Comma-separated usernames promoted to the `admin` role on auth-service startup.
# Admin-authored catalog entries are surfaced as "canonical" (Канонічні).
ADMIN_USERNAMES=

# Internal service URLs (used by services to call each other)
AUTH_SERVICE_URL=http://auth:3001

# Adminer (DB web UI). Login = the POSTGRES_* credentials above; Adminer has no
# separate account of its own.
ADMINER_PORT=8080
# Prod only: host interface the UI binds to. 127.0.0.1 = SSH tunnel only (default).
ADMINER_BIND=127.0.0.1
# Must be a self-contained design — the image ships no fonts/ or images/, so
# themes pointing at ../fonts/entypo.woff (bilal-dark, dracula) show "?" icons.
# Known-good: pepa-linha, flat, nette, rmsoft_blue, hever.
ADMINER_DESIGN=pepa-linha
